export function add(a: i32, b: i32): i32 {
  return (a + b) as i32;
}

export function multiply(a: i32, b: i32): i32 {
  return (a * b) as i32;
}

export function subtract(a: i32, b: i32): i32 {
  return (a - b) as i32;
}

export function texte(a: String): String {
  return a;
}
